<div class="min-h-full flex items-center justify-center">
  <div class="text-center">
    <h1 class="font-serif text-5xl mb-4">Welcome to the Minimal Profile
      Platform!
    </h1>
    <p class="text-lg italic text-[color:var(--muted)] mb-8">Manage your
      personal profile with ease.</p>
    <button
      class="bg-[color:var(--accent)] text-white px-6 py-3 rounded-lg hover:opacity-80 transition no-underline inline-block"
    >
      {{#if currentUser}}
        <a href="/profile" class="text-white no-underline">View Profile →</a>
      {{else}}
        <a href="/login" class="text-white no-underline">Get Started →</a>
      {{/if}}
    </button>
  </div>
</div>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <script src='https://cdn.tailwindcss.com'></script>
    <link rel='stylesheet' href='/css/style.css' />
    <title>{{pageTitle}}</title>
  </head>
  <body class='theme-{{theme}} min-h-screen flex flex-col justify-between bg-[color:var(--bg)] text-[color:var(--text)] transition-colors duration-300'>
    {{>header}}

    <main class="flex-grow container max-w-6xl mx-auto px-6 py-8">
      {{{body}}}
    </main>

    {{>footer}}
  </body>
</html>
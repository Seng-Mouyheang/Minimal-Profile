<div class="pt-12">
  <div
    class="mx-auto max-w-[500px] rounded-[24px] border border-[color:var(--surface-border)] bg-[color:var(--surface)] p-10 text-[color:var(--text)] shadow-xl"
  >
    <div class="mb-8 text-center">
      <h2 class="m-0 text-2xl font-bold">Login</h2>
      <p class="mt-2 text-[color:var(--muted)]">Please enter your credentials to
        continue.</p>
    </div>
    {{#if errorMessage}}
      <div
        class="mb-6 rounded-lg bg-red-100 p-4 text-sm text-red-700 border border-red-200"
      >
        {{errorMessage}}
      </div>
    {{/if}}

    <form action="/login" method="POST" class="space-y-6">

      <div class="text-left">
        <label
          for="username"
          class="mb-2 block text-sm font-medium text-[color:var(--text)]"
        >
          Username:
        </label>
        <input
          type="text"
          id="username"
          name="username"
          placeholder="e.g., John Doe"
          required
          class="w-full rounded-xl border border-[color:var(--surface-border)] bg-[color:var(--surface)] p-3 text-[color:var(--text)] transition-colors duration-200 focus:border-[color:var(--accent)] focus:outline-none"
        />
      </div>

      <div class="text-left">
        <label
          for="password"
          class="mb-2 block text-sm font-medium text-[color:var(--text)]"
        >
          Password:
        </label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="*********"
          required
          class="w-full rounded-xl border border-[color:var(--surface-border)] bg-[color:var(--surface)] p-3 text-[color:var(--text)] transition-colors duration-200 focus:border-[color:var(--accent)] focus:outline-none"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-xl bg-[color:var(--accent)] p-4 font-bold text-white transition-all duration-200 hover:-translate-y-0.5 hover:opacity-80"
      >
        Login
      </button>
    </form>
  </div>
</div>